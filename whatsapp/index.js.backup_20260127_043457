// Vincular número de WhatsApp a usuario (usa token de autenticación)
app.post('/api/link-phone', async (req, res) => {
  try {
    // Obtener token de los headers
    const authHeader = req.headers.authorization || req.headers['x-auth-token'];
    const token = authHeader ? authHeader.replace(/^Bearer\s+/i, '') : null;
    
    if (!token) {
      return res.status(401).json({ error: 'Token de autenticación requerido' });
    }
    
    // Obtener user_id desde el token
    const userId = await getUserIdFromToken(token);
    
    if (!userId) {
      return res.status(401).json({ error: 'Token inválido o usuario no encontrado' });
    }
    
    // ❌ CRÍTICO: Prevenir que usuarios admin vinculen WhatsApp
    // Verificar el role del usuario antes de continuar
    const dbCheckRole = getDb();
    dbCheckRole.get(
      'SELECT id, username, role FROM users WHERE id = ?',
      [userId],
      (errRole, userRow) => {
        dbCheckRole.close();
        if (errRole) {
          console.error('❌ Error verificando role del usuario:', errRole);
          return res.status(500).json({ error: 'Error al verificar permisos del usuario' });
        }
        
        if (!userRow) {
          return res.status(401).json({ error: 'Usuario no encontrado' });
        }
        
        // ❌ BLOQUEAR ADMIN: No permitir que admin vincule WhatsApp
        if (userRow.role === 'admin') {
          console.error(`❌ BLOQUEADO: Usuario admin (ID: ${userId}, username: ${userRow.username}) intentó vincular WhatsApp`);
          console.error(`❌ Los usuarios admin NO pueden vincular WhatsApp por seguridad`);
          return res.status(403).json({ 
            error: 'Los usuarios administradores no pueden vincular WhatsApp. Esta funcionalidad está reservada para usuarios regulares.' 
          });
        }
        
        // Continuar con el proceso de vinculación solo si NO es admin
        continueLinkPhoneProcess(userId, req, res);
      }
    );
  } catch (error) {
    console.error('Error en /api/link-phone:', error);
    res.status(500).json({ error: error.message });
  }
});

// Función auxiliar para continuar el proceso de vinculación (separada para evitar anidación excesiva)
function continueLinkPhoneProcess(userId, req, res) {
  try {
    // ✅ REFACTORIZADO: Obtener ID de WhatsApp desde el socket del usuario específico
    // El formato de socket.user.id puede ser: "138916556447751:lid" o "138916556447751@s.whatsapp.net:something"
    // IMPORTANTE: Según la lógica establecida:
    // - whatsapp_id debe guardar el ID SIN sufijo (solo número, ej: 138916556447751)
    // - whatsapp_number debe guardar el número real (solo dígitos, ej: 595972908588)
    let whatsappIdFull = null; // ID completo con sufijo (ej: 138916556447751@lid o 138916556447751@s.whatsapp.net)
    let whatsappIdNumber = null; // Solo el número del ID (ej: 138916556447751) - para búsquedas
    
    const userData = userSockets.get(userId);
    if (!userData || !userData.socket) {
      return res.status(400).json({ error: 'No hay conexión de WhatsApp activa para este usuario' });
    }
    
    if (userData.socket && userData.socket.user && userData.socket.user.id) {
      const fullId = userData.socket.user.id;
      console.log(`🔍 socket.user.id completo: ${fullId}`);
      
      // Extraer el ID completo con sufijo para guardar en whatsapp_id
      // El formato puede ser: "138916556447751:lid" o "595986782672:36@s.whatsapp.net"
      // IMPORTANTE: Necesitamos preservar el formato completo con sufijo
      // Si tiene formato "numero:lid", convertir a "numero@lid"
      // Si tiene formato "numero:algo@s.whatsapp.net", extraer el número y usar formato "@lid"
      
      // Primero, intentar detectar si tiene formato ":lid" (formato más común para IDs de WhatsApp)
      if (fullId.includes(':lid')) {
        // Formato: "138916556447751:lid" -> convertir a "138916556447751@lid"
        const numberPart = fullId.split(':')[0];
        whatsappIdFull = `${numberPart}@lid`;
      } else if (fullId.includes(':')) {
        // Formato: "595986782672:36@s.whatsapp.net" o "numero:algo"
        // Extraer solo el número (antes del primer ':') y usar formato @lid
        const numberPart = fullId.split(':')[0];
        whatsappIdFull = `${numberPart}@lid`;
      } else if (fullId.includes('@')) {
        // Formato: "595986782672@s.whatsapp.net"
        // Extraer el número y convertir a formato @lid
        const numberPart = fullId.split('@')[0];
        whatsappIdFull = `${numberPart}@lid`;
      } else {
        // Solo número, agregar sufijo por defecto @lid
        whatsappIdFull = `${fullId}@lid`;
      }
      
      // Extraer solo el número (sin sufijo) para búsquedas y comparaciones
      whatsappIdNumber = fullId.split(':')[0].split('@')[0];
      
      console.log(`✅ ID WhatsApp completo (con sufijo): ${whatsappIdFull}`);
      console.log(`✅ ID WhatsApp (solo número): ${whatsappIdNumber}`);
    }
    
    // Si se proporciona whatsappId en el body, usarlo (permite override)
    if (req.body.whatsappId) {
      whatsappIdFull = req.body.whatsappId;
      whatsappIdNumber = req.body.whatsappId.split('@')[0].split(':')[0];
      console.log(`✅ ID WhatsApp desde body (completo): ${whatsappIdFull}`);
      console.log(`✅ ID WhatsApp desde body (solo número): ${whatsappIdNumber}`);
    }
    
    console.log(`🔍 [Usuario ${userId}] /api/link-phone - whatsappIdNumber: ${whatsappIdNumber}`);
    console.log(`🔍 [Usuario ${userId}] /api/link-phone - socket existe: ${!!userData.socket}, socket.user existe: ${!!(userData.socket && userData.socket.user)}`);
    console.log(`🔍 [Usuario ${userId}] /api/link-phone - body recibido:`, JSON.stringify(req.body));
    
    if (!whatsappIdNumber) {
      console.error('❌ /api/link-phone: No se pudo obtener el ID de WhatsApp desde el socket');
      return res.status(400).json({ error: 'No se pudo obtener el ID de WhatsApp. Asegúrate de que WhatsApp esté conectado.' });
    }
    
    // Obtener whatsapp_number desde el body (valor exacto que devuelve la API)
    // IMPORTANTE: NO normalizar, NO transformar, guardar exactamente como viene
    let whatsapp_number = req.body.phoneNumber || req.body.whatsapp_number;
    
    // Si no se proporciona whatsapp_number, verificar si el usuario ya tiene uno en la BD
    // Esto permite actualizar solo whatsapp_id si whatsapp_number no está disponible
    let whatsappNumberToSave = whatsapp_number;
    if (!whatsappNumberToSave) {
      console.log('⚠️  /api/link-phone: whatsapp_number no proporcionado, verificando si existe en BD...');
      const dbCheck = getDb();
      dbCheck.get(
        'SELECT whatsapp_number FROM users WHERE id = ?',
        [userId],
        (err, userRow) => {
          dbCheck.close();
          if (!err && userRow && userRow.whatsapp_number) {
            whatsappNumberToSave = userRow.whatsapp_number;
            console.log(`✅ Usando whatsapp_number existente de BD: ${whatsappNumberToSave}`);
          } else {
            // Si no hay whatsapp_number en BD y no se proporciona, usar whatsappIdNumber como temporal
            whatsappNumberToSave = whatsappIdNumber;
            console.log(`⚠️  No hay whatsapp_number en BD, usando whatsapp_id como temporal: ${whatsappNumberToSave}`);
            console.log(`💡 El whatsapp_number se puede actualizar más tarde proporcionándolo en el body`);
          }
        }
      );
    }
    
    // IMPORTANTE: Guardar exactamente el valor que viene (sin normalizar)
    if (whatsapp_number) {
      console.log(`✅ whatsapp_number recibido (valor exacto de la API): ${whatsapp_number}`);
    } else {
      console.log(`⚠️  whatsapp_number no proporcionado, se usará valor existente o temporal`);
    }
    
    // Para whatsapp_sessions, usar el ID completo con sufijo (para compatibilidad)
    // Usar whatsappIdFull si está disponible, sino construir desde whatsappIdNumber
    const formattedNumberForSession = whatsappIdFull || `${whatsappIdNumber}@s.whatsapp.net`; // Para whatsapp_sessions
    
    const db = getDb();
    
    // Verificar si el número ya está vinculado a otro usuario y continuar con la actualización
    db.get(
      'SELECT user_id, phone_number FROM whatsapp_sessions WHERE phone_number = ?',
      [formattedNumberForSession],
      async (err, existingRow) => {
        if (err) {
          db.close();
          console.error('Error verificando sesión existente:', err);
          return res.status(500).json({ error: 'Error al verificar sesión existente' });
        }
        
        if (existingRow) {
          if (existingRow.user_id !== userId) {
            // ❌ CRÍTICO: El WhatsApp ya está vinculado a OTRO usuario
            // NO permitir re-vinculación automática - esto previene que un usuario "robe" el WhatsApp de otro
            db.close();
            console.error(`❌ ERROR: El número ${formattedNumberForSession} ya está vinculado al usuario ${existingRow.user_id}`);
            console.error(`❌ El usuario ${userId} NO puede vincular este WhatsApp porque pertenece a otro usuario`);
            return res.status(409).json({ 
              error: `Este número de WhatsApp ya está vinculado a otro usuario. Solo el usuario que escaneó el QR puede vincular su WhatsApp.` 
            });
          } else {
            // Ya está vinculado al mismo usuario, solo actualizar status y fecha
            console.log(`ℹ️  El número ${formattedNumberForSession} ya está vinculado al usuario ${userId}, actualizando estado`);
          }
        }
        
        // Vincular o actualizar la sesión (INSERT OR REPLACE actualiza si existe)
        db.run(
          `INSERT OR REPLACE INTO whatsapp_sessions (user_id, phone_number, status, connected_at) 
           VALUES (?, ?, 'connected', CURRENT_TIMESTAMP)`,
          [userId, formattedNumberForSession],
          function(insertErr) {
            if (insertErr) {
              db.close();
              console.error('Error vinculando número en whatsapp_sessions:', insertErr);
              return res.status(500).json({ error: 'Error al vincular número de teléfono' });
            }
            
            console.log(`✅ Sesión de WhatsApp guardada/actualizada en whatsapp_sessions para usuario ${userId}`);
            
            // ACTUALIZAR también en la tabla users
            // IMPORTANTE: Guardar exactamente los valores que devuelve la API
            // - whatsapp_id: ID de WhatsApp SIN sufijo (ej: "138916556447751")
            // - whatsapp_number: Número real del usuario (ej: "595972908588")
            // NO normalizar, NO transformar, NO derivar uno del otro
            // Persistir exactamente lo que devuelve la API
            
            // whatsapp_id: Extraer solo el número SIN sufijo desde socket.user.id
            let whatsappIdToSave = whatsappIdNumber;
            if (!whatsappIdToSave && formattedNumberForSession) {
              whatsappIdToSave = formattedNumberForSession.split('@')[0].split(':')[0];
            }
            
            // whatsapp_number: Obtener el valor (del body, BD existente, o temporal)
            // Función para actualizar la tabla users
            const updateUsersTable = (finalWhatsappNumber) => {
              const whatsappNumberToUse = finalWhatsappNumber || whatsappIdNumber;
              
              console.log(`📝 Actualizando tabla users con valores EXACTOS de la API (sin normalizar):`);
              console.log(`   - whatsapp_id: ${whatsappIdToSave}`);
              console.log(`   - whatsapp_number: ${whatsappNumberToUse}`);
              console.log(`   - userId: ${userId}`);
              
              // Verificar que tengamos valores válidos
              if (!whatsappIdToSave) {
                console.error('❌ No se pudo obtener whatsapp_id para actualizar users');
                db.close();
                return res.status(400).json({ error: 'No se pudo obtener el whatsapp_id para actualizar' });
              }
              
              // ✅ VALIDACIÓN CRÍTICA 1:1: Verificar que este whatsapp_id NO esté ya asignado a OTRO usuario
              // Esto previene que múltiples usuarios tengan el mismo WhatsApp
              const dbCheck = getDb();
              dbCheck.get(
                'SELECT id, username FROM users WHERE whatsapp_id = ? AND id != ?',
                [whatsappIdToSave, userId],
                (checkErr, existingUser) => {
                  dbCheck.close();
                  
                  if (checkErr) {
                    console.error('❌ Error verificando whatsapp_id duplicado:', checkErr);
                    db.close();
                    return res.status(500).json({ error: 'Error al verificar duplicados' });
                  }
                  
                  if (existingUser) {
                    // ❌ CRÍTICO: Este whatsapp_id ya está asignado a OTRO usuario
                    console.error(`❌ ERROR: El whatsapp_id ${whatsappIdToSave} ya está asignado al usuario ${existingUser.id} (${existingUser.username})`);
                    console.error(`❌ El usuario ${userId} NO puede usar este WhatsApp porque pertenece a otro usuario`);
                    db.close();
                    return res.status(409).json({ 
                      error: `Este número de WhatsApp ya está vinculado a otro usuario (${existingUser.username}). Cada usuario debe tener su propio dispositivo WhatsApp.` 
                    });
                  }
                  
                  // ✅ Validación pasada: este whatsapp_id no está asignado a otro usuario
                  // Ahora podemos actualizar SOLO al usuario específico del token
                  
                  // Usar una nueva conexión de base de datos para el UPDATE
                  // ✅ VALIDACIÓN PRINCIPAL: Solo actualizar al usuario específico que está haciendo la conexión
                  // El WHERE id = ? garantiza que solo se actualice el usuario autenticado (userId del token)
                  const db2 = getDb();
                  db2.run(
                    'UPDATE users SET whatsapp_id = ?, whatsapp_number = ? WHERE id = ?',
                    [whatsappIdToSave, whatsappNumberToUse, userId],
                    function(updateErr) {
                      if (updateErr) {
                        console.error('❌ Error actualizando whatsapp_number en users:', updateErr);
                        console.error('❌ Detalles del error:', JSON.stringify(updateErr));
                        db2.close();
                        db.close();
                        // No fallar si falla la actualización en users, pero loguear y responder
                        const action = existingRow ? 'actualizado' : 'vinculado';
                        return res.json({ 
                          success: true, 
                          message: `Número ${action} en sesión, pero hubo un error al actualizar la tabla users`,
                          whatsapp_id: whatsappIdToSave,
                          whatsapp_number: whatsappNumberToUse,
                          userId: userId,
                          wasLinked: !!existingRow,
                          previousUserId: existingRow ? existingRow.user_id : null,
                          warning: 'La sesión se guardó pero la tabla users no se actualizó',
                          error: updateErr.message
                        });
                      }
                      
                      const rowsAffected = this.changes;
                      console.log(`✅ UPDATE ejecutado - Filas afectadas: ${rowsAffected}`);
                      console.log(`✅ Valores guardados EXACTAMENTE como devuelve la API (sin normalizar):`);
                      console.log(`   - whatsapp_id: ${whatsappIdToSave}`);
                      console.log(`   - whatsapp_number: ${whatsappNumberToUse}`);
                      console.log(`   - Usuario: ${userId}`);
                      
                      // ✅ REFACTORIZADO: Actualizar variables locales del usuario (NO globales)
                      const userDataUpdate = userSockets.get(userId);
                      if (userDataUpdate) {
                        userDataUpdate.whatsappId = whatsappIdToSave;
                        userDataUpdate.whatsappNumber = whatsappNumberToUse;
                      }
                      
                      // Verificar que se actualizó correctamente
                      db2.get('SELECT whatsapp_id, whatsapp_number FROM users WHERE id = ?', [userId], (verifyErr, verifyRow) => {
                        db2.close();
                        db.close();
                        if (verifyErr) {
                          console.error('❌ Error verificando actualización:', verifyErr);
                        } else if (verifyRow) {
                          console.log(`✅ Verificación: Usuario ${userId} - whatsapp_id=${verifyRow.whatsapp_id}, whatsapp_number=${verifyRow.whatsapp_number}`);
                          // ✅ CRÍTICO: Actualizar SOLO variables locales del usuario (NO globales)
                          const userDataVerify = userSockets.get(userId);
                          if (userDataVerify) {
                            userDataVerify.whatsappId = verifyRow.whatsapp_id;
                            userDataVerify.whatsappNumber = verifyRow.whatsapp_number;
                          }
                          // ❌ ELIMINADO: No actualizar variables globales connectedWhatsAppId/connectedWhatsAppNumber
                        }
                        
                        const action = existingRow ? 'actualizado' : 'vinculado';
                        console.log(`✅ Usuario ${userId} ${action} correctamente con valores EXACTOS de la API`);
                        res.json({ 
                          success: true, 
                          message: `Usuario ${action} correctamente`,
                          whatsapp_id: whatsappIdToSave,
                          whatsapp_number: whatsappNumberToUse,
                          userId: userId,
                          wasLinked: !!existingRow,
                          previousUserId: existingRow ? existingRow.user_id : null,
                          rowsAffected: rowsAffected
                        });
                      });
                    }
                  ); // Cierre de db2.run
                } // Cierre del callback de dbCheck.get (arrow function)
            ); // Cierre de dbCheck.get
            };
            
            // Obtener whatsapp_number: del body, BD existente, o temporal
            if (whatsapp_number) {
              // Si se proporcionó en el body, usarlo directamente
              console.log(`✅ whatsapp_number recibido (valor exacto de la API): ${whatsapp_number}`);
              updateUsersTable(whatsapp_number);
            } else {
              // Si no se proporcionó, buscar en BD
              const dbCheck = getDb();
              dbCheck.get(
                'SELECT whatsapp_number FROM users WHERE id = ?',
                [userId],
                (err, userRow) => {
                  dbCheck.close();
                  if (!err && userRow && userRow.whatsapp_number) {
                    console.log(`✅ Usando whatsapp_number existente de BD: ${userRow.whatsapp_number}`);
                    updateUsersTable(userRow.whatsapp_number);
                  } else {
                    // Si no hay en BD, usar whatsappIdNumber como temporal
                    console.log(`⚠️  No hay whatsapp_number en BD, usando whatsapp_id como temporal: ${whatsappIdNumber}`);
                    console.log(`💡 El whatsapp_number se puede actualizar más tarde proporcionándolo en el body`);
                    updateUsersTable(whatsappIdNumber);
                  }
                }
              );
            }
          }
        );
      }
    );
  } catch (error) {
    console.error('Error en continueLinkPhoneProcess:', error);
    res.status(500).json({ error: error.message });
  }
}


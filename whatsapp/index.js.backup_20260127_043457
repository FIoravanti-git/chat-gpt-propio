// Función helper para acceder a la base de datos
function getDb() {
  return new sqlite3.Database(AUTH_DB_PATH);
}

// Normalizar número de teléfono para búsqueda consistente
function normalizePhoneNumber(phoneNumber) {
  // Remover sufijos de WhatsApp (@s.whatsapp.net, @g.us, etc.)
  let normalized = phoneNumber.replace(/@[^@]+$/, '');
  // Remover caracteres no numéricos excepto +
  normalized = normalized.replace(/[^\d+]/g, '');
  return normalized;
}

// Obtener número de WhatsApp real del usuario (solo dígitos)
function getUserRealPhoneNumber(userId) {
  return new Promise((resolve, reject) => {
    const db = getDb();
    // PRIORIDAD 1: Buscar en users.whatsapp_number (número real normalizado)
    db.get(
      'SELECT whatsapp_number FROM users WHERE id = ?',
      [userId],
      (err, row) => {
        if (err) {
          db.close();
          console.error('Error obteniendo número real del usuario:', err);
          resolve(null);
        } else if (row && row.whatsapp_number) {
          db.close();
          console.log(`✅ Número real encontrado en users.whatsapp_number: ${row.whatsapp_number}`);
          resolve(row.whatsapp_number);
        } else {
          // PRIORIDAD 2: Si no hay whatsapp_phone_number, obtener desde whatsapp_sessions y normalizar
          const db2 = getDb();
          db2.get(
            'SELECT phone_number FROM whatsapp_sessions WHERE user_id = ? LIMIT 1',
            [userId],
            (err2, row2) => {
              db2.close();
              if (err2) {
                console.error('Error obteniendo número desde whatsapp_sessions:', err2);
                resolve(null);
              } else if (row2 && row2.phone_number) {
                // Normalizar el número de la sesión
                const normalized = normalizePhoneNumber(row2.phone_number);
                console.log(`✅ Número obtenido desde whatsapp_sessions y normalizado: ${normalized}`);
                resolve(normalized);
              } else {
                console.warn(`⚠️  No se encontró número de WhatsApp para usuario ${userId}`);
                resolve(null);
              }
            }
          );
        }
      }
    );
  });
}

// Obtener user_id desde número de teléfono o sesión
// PRIORIDAD: Buscar primero por whatsapp_number (número real) para validar usuario conectado
function getUserFromPhoneNumber(phoneNumber) {
  return new Promise((resolve, reject) => {
    const db = getDb();
    // Normalizar número para búsqueda consistente (solo dígitos)
    const normalizedNumber = normalizePhoneNumber(phoneNumber);
    
    console.log(`🔍 Buscando usuario para número: ${phoneNumber} (normalizado: ${normalizedNumber})`);
    
    // PRIORIDAD 1: Buscar en users.whatsapp_number (número real del usuario)
    // Este es el campo principal para validar si corresponde al usuario conectado
    db.get(
      `SELECT id FROM users 
       WHERE whatsapp_number = ? 
       OR whatsapp_number = ?`,
      [normalizedNumber, phoneNumber],
      (err1, userRow1) => {
        if (err1) {
          console.error('Error buscando usuario por whatsapp_number:', err1);
        } else if (userRow1) {
          db.close();
          console.log(`✅ Usuario encontrado en tabla users (whatsapp_number): ${userRow1.id}`);
          console.log(`✅ Validación: El número ${normalizedNumber} corresponde al usuario ${userRow1.id}`);
          resolve(userRow1.id);
          return;
        }
        
        // PRIORIDAD 2: Buscar en whatsapp_sessions por número exacto (formato completo con sufijos)
        // Esto es importante porque los mensajes pueden llegar con diferentes formatos (@s.whatsapp.net, @lid, etc.)
        db.get(
          'SELECT user_id FROM whatsapp_sessions WHERE phone_number = ?',
          [phoneNumber],
          (err2, row2) => {
            if (err2) {
              console.error('Error buscando en whatsapp_sessions (formato exacto):', err2);
            } else if (row2) {
              db.close();
              console.log(`✅ Usuario encontrado en whatsapp_sessions (formato exacto): ${row2.user_id}`);
              resolve(row2.user_id);
              return;
            }
            
            // PRIORIDAD 3: Buscar en whatsapp_sessions con número normalizado + diferentes sufijos
            // Probar con @s.whatsapp.net, @lid, y otros formatos comunes
            db.get(
              `SELECT user_id FROM whatsapp_sessions 
               WHERE phone_number LIKE ? 
               OR phone_number LIKE ?
               OR phone_number = ?`,
              [`${normalizedNumber}@%`, `%${normalizedNumber}%`, normalizedNumber],
              (err3, row3) => {
                if (err3) {
                  console.error('Error buscando en whatsapp_sessions (variantes):', err3);
                } else if (row3) {
                  db.close();
                  console.log(`✅ Usuario encontrado en whatsapp_sessions (variantes): ${row3.user_id}`);
                  resolve(row3.user_id);
                  return;
                }
                
                // PRIORIDAD 4: Buscar en la tabla users por whatsapp_id (formato completo con sufijo)
                // Los mensajes llegan con formato @lid, así que debemos buscar con ese formato
                // También buscar variantes para compatibilidad
                const searchVariantsForUsers = [
                  phoneNumber, // Formato exacto del mensaje (ej: 138916556447751@lid)
                  `${normalizedNumber}@lid`, // Formato normalizado con @lid
                  `${normalizedNumber}@s.whatsapp.net`, // Formato alternativo
                  normalizedNumber // Solo número para compatibilidad
                ];
                db.get(
                  `SELECT id FROM users 
                   WHERE whatsapp_id = ? 
                   OR whatsapp_id = ?
                   OR whatsapp_id = ?
                   OR whatsapp_id = ?
                   OR whatsapp_id LIKE ?`,
                  [...searchVariantsForUsers, `%${normalizedNumber}%`],
                  (err4, userRow2) => {
                    db.close();
                    if (err4) {
                      console.error('Error buscando usuario por whatsapp_id:', err4);
                      reject(err4);
                    } else if (userRow2) {
                      console.log(`✅ Usuario encontrado en tabla users (whatsapp_id): ${userRow2.id}`);
                      resolve(userRow2.id);
                    } else {
                      // No se encontró usuario - retornar null (aislamiento estricto)
                      console.warn(`⚠️  No se encontró usuario para número: ${phoneNumber} (normalizado: ${normalizedNumber})`);
                      console.warn(`⚠️  Buscado en: users.whatsapp_number, whatsapp_sessions.phone_number, users.whatsapp_id`);
                      resolve(null);
                    }
                  }
                );
              }
            );
          }
        );
      }
    );
  });
}

// Obtener token del usuario
function getUserToken(userId) {
  return new Promise((resolve, reject) => {
    const db = getDb();
    db.get(
      'SELECT token FROM users WHERE id = ?',
      [userId],
      (err, row) => {
        db.close();
        if (err) {
          reject(err);
        } else if (row && row.token) {
          resolve(row.token);
        } else {
          resolve(null);
        }
      }
    );
  });
}

// Obtener user_id desde token de autenticación
function getUserIdFromToken(token) {
  return new Promise((resolve, reject) => {
    if (!token) {
      resolve(null);
      return;
    }
    
    const db = getDb();
    // Limpiar el token (puede venir con "Bearer " prefix)
    const cleanToken = token.replace(/^Bearer\s+/i, '');
    
    db.get(
      'SELECT id, username FROM users WHERE token = ?',
      [cleanToken],
      (err, row) => {
        db.close();
        if (err) {
          reject(err);
        } else if (row) {
          resolve(row.id);
        } else {
          resolve(null);
        }
      }
    );
  });
}

// Obtener o crear conversación de WhatsApp para un usuario
function getOrCreateWhatsAppConversation(userId, phoneNumber) {
  return new Promise((resolve, reject) => {
    const db = getDb();
    // Buscar conversación existente de WhatsApp para este usuario
    db.get(
      `SELECT c.id, c.title, c.updated_at 
       FROM conversations c
       JOIN whatsapp_sessions w ON c.whatsapp_session_id = w.id
       WHERE c.user_id = ? AND c.channel = 'whatsapp' AND w.phone_number = ?
       ORDER BY c.updated_at DESC
       LIMIT 1`,
      [userId, phoneNumber],
      (err, row) => {
        if (err) {
          db.close();
          reject(err);
        } else if (row) {
          db.close();
          resolve(row.id);
        } else {
          // Crear nueva conversación
          // Primero obtener o crear sesión de WhatsApp
          db.get(
            'SELECT id FROM whatsapp_sessions WHERE user_id = ?',
            [userId],
            (err2, sessionRow) => {
              if (err2) {
                db.close();
                reject(err2);
              } else {
                let sessionId = sessionRow ? sessionRow.id : null;
                
                // Si no hay sesión, crear una
                if (!sessionId) {
                  db.run(
                    'INSERT INTO whatsapp_sessions (user_id, phone_number, status) VALUES (?, ?, ?)',
                    [userId, phoneNumber, 'connected'],
                    function(err3) {
                      if (err3) {
                        db.close();
                        reject(err3);
                      } else {
                        sessionId = this.lastID;
                        // Crear conversación
                        db.run(
                          'INSERT INTO conversations (user_id, channel, whatsapp_session_id, title) VALUES (?, ?, ?, ?)',
                          [userId, 'whatsapp', sessionId, `Chat WhatsApp ${phoneNumber}`],
                          function(err4) {
                            db.close();
                            if (err4) {
                              reject(err4);
                            } else {
                              resolve(this.lastID);
                            }
                          }
                        );
                      }
                    }
                  );
                } else {
                  // Crear conversación con sesión existente
                  db.run(
                    'INSERT INTO conversations (user_id, channel, whatsapp_session_id, title) VALUES (?, ?, ?, ?)',
                    [userId, 'whatsapp', sessionId, `Chat WhatsApp ${phoneNumber}`],
                    function(err4) {
                      db.close();
                      if (err4) {
                        reject(err4);
                      } else {
                        resolve(this.lastID);
                      }
                    }
                  );
                }
              }
            }
          );
        }
      }
    );
  });
}

// Guardar mensaje en la base de datos y auditoría
function saveMessage(conversationId, userId, role, content, phoneNumber = null, whatsappId = null) {
  return new Promise((resolve, reject) => {
    const db = getDb();
    db.run(
      'INSERT INTO messages (conversation_id, role, content) VALUES (?, ?, ?)',
      [conversationId, role, content],
      function(err) {
        if (err) {
          db.close();
          reject(err);
          return;
        }
        
        const messageId = this.lastID;
        
        // Actualizar updated_at de la conversación
        db.run(
          'UPDATE conversations SET updated_at = CURRENT_TIMESTAMP WHERE id = ?',
          [conversationId],
          (err2) => {
            if (err2) {
              console.error('Error actualizando conversación:', err2);
            }
            
            // AUDITORÍA: Registrar en tabla de auditoría
            // IMPORTANTE: Aplicar la misma lógica que en la tabla users
            // whatsapp_id: ID de WhatsApp sin sufijo (ej: 138916556447751) - sin @s.whatsapp.net ni @lid
            // whatsapp_number: Número real de teléfono (solo dígitos, ej: 595972908588) - diferente al whatsapp_id
            const direction = role === 'user' ? 'incoming' : 'outgoing';
            
            // Normalizar número real (solo dígitos) - este es whatsapp_number
            // Debe ser el número real de teléfono del usuario, no el ID de WhatsApp
            const phoneNumberOnly = phoneNumber ? (phoneNumber.includes('@') ? normalizePhoneNumber(phoneNumber) : phoneNumber) : null;
            
            // Normalizar ID de WhatsApp (solo número, sin sufijo) - este es whatsapp_id
            // Debe ser el ID de WhatsApp sin sufijo (ej: 138916556447751), sin @s.whatsapp.net ni @lid
            let whatsappIdOnly = null;
            if (whatsappId) {
              // Remover cualquier sufijo (@s.whatsapp.net, @lid, :algo, etc.)
              whatsappIdOnly = whatsappId.split('@')[0].split(':')[0];
            }
            
            console.log(`📝 Auditoría - whatsapp_id: ${whatsappIdOnly || 'NULL'}, whatsapp_number: ${phoneNumberOnly || 'NULL'}`);
            console.log(`📝 Nota: whatsapp_id es el ID de WhatsApp sin sufijo, whatsapp_number es el número real de teléfono`);
            db.run(
              `INSERT INTO conversation_audit 
               (user_id, conversation_id, channel, direction, role, content, whatsapp_id, whatsapp_number, message_id)
               VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,
              [userId, conversationId, 'whatsapp', direction, role, content, whatsappIdOnly, phoneNumberOnly, messageId],
              (err3) => {
                db.close();
                if (err3) {
                  console.error('Error guardando auditoría:', err3);
                  // No fallar si falla la auditoría, solo loguear
                }
                resolve(messageId);
              }
            );
          }
        );
      }
    );
  });
}

// Función para consultar Quivr con contexto del usuario
async function queryQuivr(message, userToken, conversationId = null) {
  try {
    const quivrEndpoint = `${quivrConfig.url}${quivrConfig.endpoint}`;
    console.log('Consultando Quivr en:', quivrEndpoint);
    console.log('Usuario autenticado, usando contexto específico del usuario');
    
    const payload = {
      question: message
    };
    
    // Agregar conversation_id si está disponible (para contexto histórico)
    if (conversationId) {
      payload.conversation_id = conversationId;
    }
    
    // Agregar channel
    payload.channel = 'whatsapp';
    
    if (quivrConfig.k) payload.k = quivrConfig.k;
    if (quivrConfig.temperature !== undefined) payload.temperature = quivrConfig.temperature;
    
    console.log('Payload enviado a Quivr:', JSON.stringify(payload));

    // Enviar token del usuario para que Quivr use su contexto
    const headers = {
      'Content-Type': 'application/json'
    };
    
    if (userToken) {
      headers['Authorization'] = `Bearer ${userToken}`;
      // También soportar X-Auth-Token como alternativa
      headers['X-Auth-Token'] = userToken;
    }

    const response = await axios.post(quivrEndpoint, payload, {
      headers: headers,
      timeout: 30000
    });

    let answer = null;
    if (response.data) {
      answer = response.data.answer || 
               response.data.response || 
               response.data.message || 
               response.data.text ||
               (typeof response.data === 'string' ? response.data : JSON.stringify(response.data));
    }

    return answer || 'No pude obtener una respuesta de Quivr.';
  } catch (error) {
    console.error('Error consultando Quivr:', error.message);
    if (error.response) {
      console.error('Respuesta de Quivr:', error.response.status, error.response.data);
    }
    // NO usar fallback a contexto global - lanzar error si no hay token válido
    if (error.response && error.response.status === 401) {
      throw new Error('Usuario no autenticado. No se puede acceder al contexto del usuario.');
    }
    throw error;
  }
}

// ✅ REFACTORIZADO: Inicializar cliente de WhatsApp para un usuario específico
// IMPORTANTE: Cada usuario debe tener su propia conexión
async function initializeWhatsApp(userId) {
  if (!userId) {
    throw new Error('userId es requerido para inicializar WhatsApp');
  }
  
  console.log(`🔧 Inicializando WhatsApp para usuario ${userId}`);
  
  // Directorio de autenticación específico por usuario
  const authDir = path.join(__dirname, 'baileys_auth', `user_${userId}`);
  const { state, saveCreds } = await useMultiFileAuthState(authDir);
  
  const { version } = await fetchLatestBaileysVersion();
  
  // ✅ CRÍTICO: Crear socket como variable local, NO global
  const socket = makeWASocket({
    version,
    logger,
    printQRInTerminal: true,
    auth: state,
    browser: ['Chrome', 'Chrome', '120.0'],
    // Configuración adicional para mejorar la conexión
    connectTimeoutMs: 90000,
    defaultQueryTimeoutMs: 90000,
    keepAliveIntervalMs: 30000,
    qrTimeout: 120000, // 120 segundos para escanear el QR
    // Configuración adicional para evitar errores de conexión
    markOnlineOnConnect: true,
    syncFullHistory: false,
    generateHighQualityLinkPreview: false,
    // Configuración para evitar errores 428
    retryRequestDelayMs: 250,
    maxMsgRetryCount: 3,
    getMessage: async (key) => {
      return {
        conversation: 'Mensaje no disponible'
      };
    }
  });

  socket.ev.on('creds.update', saveCreds);
  
  // ✅ CRÍTICO: Verificar si ya hay una sesión activa Y validar que pertenece a este usuario
  setTimeout(async () => {
    const userDataCheck = userSockets.get(userId);
    if (userDataCheck && userDataCheck.socket && userDataCheck.socket.user) {
      const fullId = userDataCheck.socket.user.id;
      const whatsappIdFromSession = fullId.split(':')[0].split('@')[0];
      
      // ✅ VALIDACIÓN CRÍTICA: Verificar que este whatsapp_id pertenece realmente a este usuario
      const db = getDb();
      db.get(
        'SELECT id, whatsapp_id FROM users WHERE id = ? AND whatsapp_id = ?',
        [userId, whatsappIdFromSession],
        (err, userRow) => {
          db.close();
          
          if (err) {
            console.error(`❌ [Usuario ${userId}] Error validando sesión existente:`, err);
            // Si hay error, NO marcar como listo - forzar nuevo QR
            return;
          }
          
          if (userRow && userRow.id === userId && userRow.whatsapp_id === whatsappIdFromSession) {
            // ✅ Sesión válida: pertenece a este usuario
            console.log(`✅ [Usuario ${userId}] Sesión existente válida detectada, marcando como listo`);
            userDataCheck.isReady = true;
            userDataCheck.currentQR = null;
            userDataCheck.whatsappId = whatsappIdFromSession;
          } else {
            // ❌ CRÍTICO: Esta sesión NO pertenece a este usuario
            console.error(`❌ [Usuario ${userId}] Sesión existente NO válida - whatsapp_id ${whatsappIdFromSession} no pertenece a este usuario`);
            console.error(`❌ [Usuario ${userId}] Cerrando sesión inválida y forzando nuevo QR`);
            // Cerrar socket y limpiar sesión
            if (userDataCheck.socket) {
              userDataCheck.socket.end();
              userDataCheck.socket = null;
            }
            userSockets.delete(userId);
            // Limpiar directorio de autenticación para forzar nuevo QR
            const fs = require('fs');
            const authDir = path.join(__dirname, 'baileys_auth', `user_${userId}`);
            try {
              const credsPath = path.join(authDir, 'creds.json');
              if (fs.existsSync(credsPath)) {
                fs.unlinkSync(credsPath);
                console.log(`✅ [Usuario ${userId}] Sesión inválida eliminada`);
              }
            } catch (cleanErr) {
              console.error(`[Usuario ${userId}] Error limpiando sesión inválida:`, cleanErr);
            }
          }
        }
      );
    }
  }, 3000);

  // ✅ REFACTORIZADO: Manejo de QR y conexión específico por usuario
  socket.ev.on('connection.update', (update) => {
    const { connection, lastDisconnect, qr } = update;
    const userData = userSockets.get(userId);

    if (!userData) {
      console.error(`❌ Error: No se encontró datos para usuario ${userId}`);
      return;
    }

    console.log(`🔄 [Usuario ${userId}] Estado de conexión:`, connection, 'QR disponible:', !!qr);
    console.log(`🔄 [Usuario ${userId}] JSON completo del connection.update:`, JSON.stringify(update, null, 2));

    // Generar QR si está disponible
    if (qr) {
      console.log(`📱 [Usuario ${userId}] Generando QR para conectar...`);
      console.log(`📱 [Usuario ${userId}] QR recibido, generando imagen...`);
      QRCode.toDataURL(qr, {
        errorCorrectionLevel: 'M',
        type: 'image/png',
        quality: 0.92,
        margin: 1
      }).then((dataUrl) => {
        userData.currentQR = dataUrl;
        userData.qrScannedBy = userId; // Marcar que este QR pertenece a este usuario
        console.log(`✅ [Usuario ${userId}] QR generado correctamente`);
        console.log(`📱 [Usuario ${userId}] QR disponible en /api/qr - Escanea este código con WhatsApp`);
        console.log(`⏱️  [Usuario ${userId}] El QR expira en ~20 segundos, se generará uno nuevo automáticamente`);
      }).catch((err) => {
        console.error(`❌ [Usuario ${userId}] Error generando QR:`, err);
        userData.currentQR = null;
      });
    } else {
      // Si no hay QR y no está conectado, limpiar QR anterior
      if (connection !== 'open' && !userData.isReady) {
        // Si está en estado 'connecting' y no hay QR después de un tiempo, puede necesitar forzar QR
        if (connection === 'connecting') {
          console.log(`⏳ [Usuario ${userId}] Conectando... Si tarda mucho, puede necesitar nuevo QR`);
        }
        userData.currentQR = null;
      }
    }

    // ✅ REFACTORIZADO: Manejar estado de conexión específico por usuario
    if (connection === 'close') {
      const error = lastDisconnect?.error;
      const statusCode = error?.output?.statusCode;
      const errorMessage = error?.message || error?.toString() || '';
      const shouldReconnect = statusCode !== DisconnectReason.loggedOut;
      
      console.log(`[Usuario ${userId}] Conexión cerrada. Error:`, errorMessage);
      console.log(`[Usuario ${userId}] Código de estado:`, statusCode);
      console.log(`[Usuario ${userId}] Reconectando:`, shouldReconnect);
      
      userData.isReady = false;
      
      // Detectar errores específicos que requieren limpiar sesión
      // NOTA: "restart required" (515) puede ser temporal, no siempre requiere limpiar sesión
      // Solo limpiar si es un error crítico de autenticación o sesión corrupta
      const needsSessionCleanup = 
        statusCode === 401 || 
        statusCode === DisconnectReason.badSession ||
        (statusCode === DisconnectReason.restartRequired && errorMessage.includes('conflict')) ||
        errorMessage.includes('conflict') ||
        (errorMessage.includes('Stream Errored') && errorMessage.includes('conflict'));
      
      // Para "restart required" sin conflicto, solo reconectar sin limpiar sesión
      const isRestartRequired = 
        statusCode === DisconnectReason.restartRequired ||
        (errorMessage.includes('restart required') && !errorMessage.includes('conflict'));
      
      if (needsSessionCleanup) {
        console.log(`⚠️ [Usuario ${userId}] Error crítico detectado que requiere limpiar sesión. Eliminando sesión para generar nuevo QR...`);
        console.log(`⚠️ [Usuario ${userId}] Detalles del error - StatusCode: ${statusCode}, Message: ${errorMessage}`);
        userData.currentQR = null;
        userData.isReady = false;
        
        // Cerrar socket actual si existe
        if (userData.socket) {
          try {
            userData.socket.end();
            userData.socket = null;
          } catch (err) {
            console.error(`[Usuario ${userId}] Error cerrando socket:`, err);
          }
        }
        
        // Limpiar sesión corrupta específica del usuario
        const fs = require('fs');
        const authDir = path.join(__dirname, 'baileys_auth', `user_${userId}`);
        try {
          // Eliminar creds.json si existe
          const credsPath = path.join(authDir, 'creds.json');
          if (fs.existsSync(credsPath)) {
            fs.unlinkSync(credsPath);
            console.log(`✅ [Usuario ${userId}] creds.json eliminado`);
          }
          
          // Limpiar también otros archivos de sesión críticos
          if (fs.existsSync(authDir)) {
            const files = fs.readdirSync(authDir);
            const criticalFiles = files.filter(f => 
              f.startsWith('app-state-sync-key-') || 
              f.startsWith('app-state-sync-version-') ||
              f.startsWith('pre-key-') ||
              f.startsWith('session-') ||
              f.startsWith('sender-key-')
            );
            
            if (criticalFiles.length > 0) {
              console.log(`⚠️ [Usuario ${userId}] Limpiando ${criticalFiles.length} archivos de sesión críticos...`);
              criticalFiles.forEach(file => {
                try {
                  fs.unlinkSync(path.join(authDir, file));
                  console.log(`✅ [Usuario ${userId}] Eliminado: ${file}`);
                } catch (err) {
                  console.error(`[Usuario ${userId}] Error eliminando ${file}:`, err);
                }
              });
            }
          }
          
        } catch (err) {
          console.error(`[Usuario ${userId}] Error eliminando sesión:`, err);
        }
        
        // Esperar un poco antes de reinicializar para asegurar que se genere QR
        setTimeout(() => {
          console.log(`🔄 [Usuario ${userId}] Reinicializando WhatsApp después de limpiar sesión...`);
          initializeWhatsApp(userId);
        }, 5000); // Aumentar tiempo de espera para asegurar limpieza completa
      } else if (isRestartRequired) {
        // Para "restart required" sin conflicto, solo reconectar (no limpiar sesión)
        console.log(`🔄 [Usuario ${userId}] Reinicio requerido detectado (sin conflicto). Reconectando sin limpiar sesión...`);
        userData.currentQR = null;
        setTimeout(() => {
          console.log(`🔄 [Usuario ${userId}] Reinicializando WhatsApp...`);
          initializeWhatsApp(userId);
        }, 8000); // Esperar más tiempo para evitar errores 428
      } else if (shouldReconnect) {
        userData.currentQR = null;
        console.log(`🔄 [Usuario ${userId}] Intentando reconectar...`);
        // Para errores 428, esperar más tiempo antes de reconectar
        const waitTime = statusCode === 428 ? 15000 : 5000;
        setTimeout(() => {
          initializeWhatsApp(userId);
        }, waitTime);
      } else {
        userData.currentQR = null;
        console.log(`⚠️ [Usuario ${userId}] No se puede reconectar. Usa /api/force-qr para generar un nuevo QR.`);
      }
    } else if (connection === 'open') {
      console.log(`✅ [Usuario ${userId}] ¡Cliente de WhatsApp listo!`);
      console.log(`✅ [Usuario ${userId}] Conexión establecida correctamente`);
      userData.isReady = true;
      userData.currentQR = null;
      
      // ✅ CRÍTICO: NO actualizar la BD automáticamente aquí
      // La actualización SOLO debe ocurrir cuando el usuario explícitamente llama a /api/link-phone
      // Este evento solo actualiza las variables locales del usuario
      try {
        // Intentar obtener el ID de WhatsApp desde el socket
        const fullId = userData.socket.user?.id || null;
        if (fullId) {
          console.log(`📱 [Usuario ${userId}] socket.user.id completo:`, fullId);
          
          // Extraer whatsapp_id (sin sufijo) desde socket.user.id
          const whatsappId = fullId.split(':')[0].split('@')[0];
          userData.whatsappId = whatsappId;
          
          console.log(`📱 [Usuario ${userId}] ID WhatsApp extraído (whatsapp_id): ${whatsappId}`);
          console.log(`⚠️  [Usuario ${userId}] NO se actualiza la BD automáticamente. La actualización solo ocurre cuando el usuario llama a /api/link-phone`);
          console.log(`💡 [Usuario ${userId}] El usuario ${userId} debe llamar a /api/link-phone para vincular este WhatsApp`);
        } else {
          console.warn(`⚠️ [Usuario ${userId}] No se pudo obtener el ID de WhatsApp desde socket.user`);
          userData.whatsappId = null;
          userData.whatsappNumber = null;
        }
      } catch (err) {
        console.error(`❌ [Usuario ${userId}] Error procesando conexión:`, err);
        userData.whatsappId = null;
        userData.whatsappNumber = null;
      }
    } else if (connection === 'connecting') {
      console.log(`🔄 [Usuario ${userId}] Conectando...`);
      // Si está conectando pero no hay QR y no está listo después de un tiempo, puede necesitar forzar QR
      setTimeout(() => {
        if (!userData.isReady && !userData.currentQR && connection === 'connecting') {
          console.log(`⚠️ [Usuario ${userId}] Conexión tardando mucho. Si no se conecta, puede necesitar nuevo QR.`);
        }
      }, 10000); // 10 segundos
    }
  });

  // ✅ REFACTORIZADO: Manejo de mensajes específico por usuario
  console.log(`📡 [Usuario ${userId}] Registrando handler de mensajes (messages.upsert)...`);
  socket.ev.on('messages.upsert', async (m) => {
    console.log(`🔔 [Usuario ${userId}] ========== EVENTO MESSAGES.UPSERT RECIBIDO ==========`);
    console.log(`🔔 [Usuario ${userId}] Cantidad de mensajes:`, m.messages?.length || 0);
    console.log(`🔔 [Usuario ${userId}] Tipo de evento:`, m.type || 'unknown');
    console.log(`🔔 [Usuario ${userId}] JSON completo del evento:`, JSON.stringify(m, null, 2));
    const messages = m.messages;
    
    for (const msg of messages) {
      // Ignorar mensajes propios
      if (msg.key.fromMe) {
        continue;
      }

      // Ignorar mensajes de grupos si está configurado
      if (quivrConfig.ignoreGroups && msg.key.remoteJid?.includes('@g.us')) {
        continue;
      }

      // Solo procesar mensajes con texto
      if (!msg.message || (!msg.message.conversation && !msg.message.extendedTextMessage)) {
        continue;
      }

      const messageText = msg.message.conversation || msg.message.extendedTextMessage?.text || '';
      const from = msg.key.remoteJid;

      if (!messageText || !from) {
        continue;
      }

      console.log(`📨 [Usuario ${userId}] ========== MENSAJE RECIBIDO ==========`);
      console.log(`📨 [Usuario ${userId}] Mensaje recibido:`, messageText);
      console.log(`👤 [Usuario ${userId}] De:`, from);
      console.log(`📱 [Usuario ${userId}] Formato completo del remitente:`, from);
      console.log(`⚙️ [Usuario ${userId}] Quivr habilitado:`, quivrConfig.enabled);
      console.log(`🔑 [Usuario ${userId}] Message key:`, JSON.stringify(msg.key));
      console.log(`📨 [Usuario ${userId}] =======================================`);

      // Enviar a webhooks
      for (const webhook of webhooks) {
        try {
          await axios.post(webhook.url, {
            from: from,
            body: messageText,
            timestamp: msg.messageTimestamp,
            isGroupMsg: from?.includes('@g.us') || false
          }, {
            headers: webhook.headers || {},
            timeout: 10000
          });
        } catch (error) {
          console.error(`Error enviando webhook a ${webhook.url}:`, error.message);
        }
      }

      // ✅ REFACTORIZADO: Si Quivr está habilitado, procesar mensaje con aislamiento por usuario
      // El mensaje llegó al socket del usuario ${userId}, así que el procesamiento es para ese usuario
      if (quivrConfig.enabled && messageText.trim().length > 0) {
        console.log(`📨 [Usuario ${userId}] Procesando mensaje con aislamiento por usuario`);
        console.log(`📱 [Usuario ${userId}] Número de teléfono del remitente:`, from);

        try {
          // PASO 1: Identificar user_id desde número de teléfono del remitente
          // SEGURIDAD: Solo buscar por el número del remitente, sin fallbacks
          // Esto asegura que solo respondemos a números explícitamente vinculados
          let userId = await getUserFromPhoneNumber(from);
          
          // Si no se encuentra con el formato exacto, intentar con número normalizado
          // pero solo variantes del mismo número del remitente
          if (!userId) {
            const normalizedFrom = normalizePhoneNumber(from);
            if (normalizedFrom && normalizedFrom !== from) {
              console.log('🔄 Intentando con número normalizado del remitente:', normalizedFrom);
              // Buscar por variantes del número del remitente (sin sufijos, con diferentes sufijos)
              const db = getDb();
              const normalizedWithSuffix = `${normalizedFrom}@s.whatsapp.net`;
              
              userId = await new Promise((resolve) => {
                // Buscar solo variantes del número del remitente
                const searchTerms = [
                  normalizedWithSuffix,
                  normalizedFrom,
                  from
                ];
                
                // Buscar primero en users.whatsapp_id (más directo)
                db.get(
                  `SELECT id FROM users 
                   WHERE whatsapp_id IN (${searchTerms.map(() => '?').join(',')})
                   OR whatsapp_id LIKE ?
                   OR whatsapp_id LIKE ?`,
                  [...searchTerms, `${normalizedFrom}@%`, `%${normalizedFrom}%`],
                  (err, userRow) => {
                    if (err || !userRow) {
                      // Si no encuentra en users, buscar en whatsapp_sessions
                      const placeholders = searchTerms.map(() => '?').join(',');
                      db.get(
                        `SELECT user_id FROM whatsapp_sessions 
                         WHERE phone_number IN (${placeholders})
                         OR phone_number LIKE ?
                         OR phone_number LIKE ?`,
                        [...searchTerms, `${normalizedFrom}@%`, `%${normalizedFrom}%`],
                        (err2, row) => {
                          db.close();
                          if (err2 || !row) {
                            resolve(null);
                          } else {
                            console.log(`✅ Usuario encontrado por búsqueda normalizada: ${row.user_id}`);
                            resolve(row.user_id);
                          }
                        }
                      );
                    } else {
                      db.close();
                      console.log(`✅ Usuario encontrado en users.whatsapp_id: ${userRow.id}`);
                      resolve(userRow.id);
                    }
                  }
                );
              });
            }
          }
          
          // SEGURIDAD: Si no se encuentra el usuario, NO responder (aislamiento estricto)
          // No usar fallbacks al número conectado - solo responder a números explícitamente vinculados
          if (!userId) {
            console.error('❌ No se encontró usuario asociado al número del remitente:', from);
            console.error('⚠️ El número debe estar explícitamente vinculado a un usuario');
            console.error('💡 El número del remitente debe coincidir con users.whatsapp_number o whatsapp_sessions.phone_number');
            console.error('💡 Sugerencia: Vincula el número desde el frontend cuando conectes WhatsApp');
            // NO responder si no hay usuario asociado (aislamiento estricto - sin fallbacks)
            continue;
          }
          
          console.log('✅ Usuario identificado:', userId);

          // PASO 2: Obtener token del usuario
          const userToken = await getUserToken(userId);
          
          if (!userToken) {
            console.error('❌ No se encontró token para el usuario:', userId);
            // NO responder si no hay token (aislamiento estricto)
            continue;
          }
          
          console.log('✅ Token obtenido para usuario:', userId);

          // PASO 2.5: Obtener número de WhatsApp real del usuario (solo dígitos)
          const realPhoneNumber = await getUserRealPhoneNumber(userId);
          console.log('📱 Número real de WhatsApp del usuario:', realPhoneNumber || 'No encontrado');

          // PASO 2.6: Obtener ID de WhatsApp del usuario (sin sufijo)
          const db = getDb();
          const whatsappId = await new Promise((resolve) => {
            db.get('SELECT whatsapp_id FROM users WHERE id = ?', [userId], (err, row) => {
              db.close();
              if (err || !row || !row.whatsapp_id) {
                // Si no hay en users, intentar normalizar desde 'from'
                const normalizedFrom = normalizePhoneNumber(from);
                resolve(normalizedFrom || null);
              } else {
                // whatsapp_id es el ID de WhatsApp sin sufijo
                resolve(row.whatsapp_id);
              }
            });
          });
          console.log('📱 ID de WhatsApp del usuario:', whatsappId || 'No encontrado');

          // PASO 3: Obtener o crear conversación de WhatsApp
          const conversationId = await getOrCreateWhatsAppConversation(userId, from);
          console.log('✅ Conversación:', conversationId);

          // PASO 4: Guardar mensaje del usuario en BD
          // IMPORTANTE: Guardar tanto el ID de WhatsApp como el número real
          await saveMessage(conversationId, userId, 'user', messageText, realPhoneNumber || null, whatsappId || null);
          console.log(`✅ Mensaje del usuario guardado - WhatsApp ID: ${whatsappId || 'NULL'}, Número: ${realPhoneNumber || 'NULL'}`);

          // PASO 5: Consultar Quivr con contexto del usuario
          console.log('🔍 Consultando Quivr con contexto del usuario:', userId);
          let answer = null;
          
          try {
            answer = await queryQuivr(messageText, userToken, conversationId);
            console.log('✅ Respuesta obtenida de Quivr');
          } catch (quivrError) {
            console.error('❌ Error consultando Quivr:', quivrError.message);
            // NO usar fallback - lanzar error
            answer = `Lo siento, ocurrió un error al procesar tu mensaje. Por favor, intenta de nuevo.`;
            // Guardar error en BD también - usar número real del usuario y ID de WhatsApp
            await saveMessage(conversationId, userId, 'assistant', answer, realPhoneNumber || null, whatsappId || null).catch(err => {
              console.error('Error guardando mensaje de error:', err);
            });
          }

          // PASO 6: Guardar respuesta del asistente en BD y auditoría
          // IMPORTANTE: Guardar tanto el ID de WhatsApp como el número real
          if (answer) {
            await saveMessage(conversationId, userId, 'assistant', answer, realPhoneNumber || null, whatsappId || null);
            console.log('✅ Respuesta del asistente guardada');
          }

          // PASO 7: Enviar respuesta por WhatsApp
          if (answer && from) {
            try {
              // IMPORTANTE: Usar el número del remitente (from) directamente para responder
              // El 'from' ya contiene el número correcto del remitente que envió el mensaje
              // Necesitamos extraer el número y formatearlo correctamente para enviar
              let chatId = null;
              
              // PRIORIDAD 1: Usar el número del remitente (from) directamente
              // Extraer el número del formato que viene (puede ser @lid, @s.whatsapp.net, etc.)
              let numberPart = from;
              
              // Si tiene formato con @, extraer solo la parte numérica
              if (from.includes('@')) {
                numberPart = from.split('@')[0];
              }
              
              // Si tiene formato con :, extraer solo la parte numérica antes del :
              if (numberPart.includes(':')) {
                numberPart = numberPart.split(':')[0];
              }
              
              // Formatear para enviar: número + @s.whatsapp.net
              chatId = `${numberPart}@s.whatsapp.net`;
              
              console.log(`📤 Número de destino extraído del remitente: ${numberPart}`);
              console.log(`📤 ChatId formateado para enviar: ${chatId}`);
              console.log(`📤 Formato original del remitente (from): ${from}`);
              console.log(`📤 whatsapp_number del usuario conectado: ${realPhoneNumber || 'No disponible'}`);
              console.log(`📤 whatsapp_id del usuario conectado: ${whatsappId || 'No disponible'}`);
              console.log('📝 Contenido:', answer.substring(0, 50) + '...');
              console.log('📏 Longitud de respuesta:', answer.length);

              // ✅ REFACTORIZADO: Usar socket del usuario que recibió el mensaje
              // El mensaje llegó al socket del usuario que tiene este WhatsApp vinculado
              // Necesitamos encontrar qué usuario tiene este socket
              let userSocket = null;
              for (const [uid, userData] of userSockets.entries()) {
                if (userData.socket && userData.socket.user && userData.socket.user.id) {
                  const socketWhatsappId = userData.socket.user.id.split(':')[0].split('@')[0];
                  if (socketWhatsappId === whatsappId) {
                    userSocket = userData.socket;
                    break;
                  }
                }
              }
              
              if (!userSocket) {
                console.error(`❌ No se encontró socket para whatsapp_id: ${whatsappId}`);
                throw new Error('Socket no encontrado para este WhatsApp');
              }
              
              // Verificar que el socket esté listo antes de enviar
              const userDataForSocket = Array.from(userSockets.values()).find(ud => ud.socket === userSocket);
              if (!userDataForSocket || !userDataForSocket.isReady) {
                console.error('❌ Socket no está listo para enviar mensajes');
                throw new Error('Socket no está listo');
              }

              await userSocket.sendMessage(chatId, { text: answer });
              console.log('✅ Mensaje enviado exitosamente a:', chatId);
            } catch (sendError) {
              console.error('❌ Error al enviar mensaje:', sendError.message);
              console.error('❌ Detalles del error:', sendError);
              console.error('❌ Formato original (from):', from);
              console.error('❌ ChatId usado:', chatId || 'N/A');
              console.error('❌ whatsapp_id del usuario:', whatsappId || 'No disponible');
              console.error('❌ whatsapp_number del usuario:', realPhoneNumber || 'No disponible');
              
              // Intentar con formato alternativo si falla
              if (sendError.message.includes('No sessions') || sendError.message.includes('session')) {
                try {
                  // Encontrar socket del usuario nuevamente
                  let userSocket = null;
                  for (const [uid, userData] of userSockets.entries()) {
                    if (userData.socket && userData.socket.user && userData.socket.user.id) {
                      const socketWhatsappId = userData.socket.user.id.split(':')[0].split('@')[0];
                      if (socketWhatsappId === whatsappId) {
                        userSocket = userData.socket;
                        break;
                      }
                    }
                  }
                  
                  if (userSocket) {
                    // Extraer solo el número (sin sufijos)
                    const numberPart = from.split('@')[0].split(':')[0];
                    const alternativeChatId = `${numberPart}@s.whatsapp.net`;
                    console.log(`🔄 Reintentando con formato alternativo (solo número): ${alternativeChatId}`);
                    await userSocket.sendMessage(alternativeChatId, { text: answer });
                    console.log('✅ Mensaje enviado exitosamente con formato alternativo');
                  }
                } catch (retryError) {
                  console.error('❌ Error en reintento:', retryError.message);
                  console.error('❌ Esto puede indicar que el número no está en la lista de contactos o hay un problema de sesión');
                }
              }
            }
          }
        } catch (error) {
          console.error('❌ Error en el procesamiento del mensaje:', error);
          console.error('❌ Stack:', error.stack);
          // NO responder si hay error (aislamiento estricto - no fallback)
        }
      }
    }
  });
}

